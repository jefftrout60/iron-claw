{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434/v1",
        "api": "openai-completions",
        "apiKey": "ollama",
        "models": [
          {
            "id": "qwen3:8b",
            "name": "Qwen3 8B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:14b",
            "name": "Qwen3 14B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "qwen2.5-coder:14b",
            "name": "Qwen2.5 Coder 14B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "llama3.2:latest",
            "name": "Llama 3.2 (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "perplexity": {
        "baseUrl": "https://api.perplexity.ai",
        "api": "openai-completions",
        "apiKey": "${PERPLEXITY_API_KEY}",
        "models": [
          {
            "id": "sonar-pro",
            "name": "Perplexity Sonar Pro (primary)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 3.0,
              "output": 15.0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 127072,
            "maxTokens": 8192
          },
          {
            "id": "sonar",
            "name": "Perplexity Sonar (heartbeat)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 1.0,
              "output": 1.0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 127072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "perplexity/sonar-pro",
        "fallbacks": [
          "ollama/qwen3:8b",
          "ollama/qwen3:14b"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "heartbeat": {
        "every": "2h",
        "model": "perplexity/sonar"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "logging": {
    "level": "debug"
  },
  "gateway": {
    "port": 18792,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18792",
        "http://127.0.0.1:18792"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["8333403651"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": [],
      "groups": {
        "*": { "requireMention": true }
      },
      "streaming": "partial",
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "skills": {
    "entries": {
      "restaurant-scout": { "enabled": false },
      "shopify-nexus": { "enabled": false },
      "fashion-radar": { "enabled": false },
      "style-profile": { "enabled": false },
      "llm-manager": { "enabled": false }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true,
        "maxChars": 100000,
        "timeoutSeconds": 45
      }
    }
  }
}

{
  "profiles": {
    "ollama:default": {
      "provider": "ollama",
      "mode": "api_key",
      "apiKey": "ollama",
      "api_key": "ollama"
    },
    "groq:default": {
      "provider": "groq",
      "mode": "api_key",
      "apiKey": "${GROQ_API_KEY}",
      "api_key": "${GROQ_API_KEY}"
    },
    "perplexity:default": {
      "provider": "perplexity",
      "mode": "api_key",
      "apiKey": "${PERPLEXITY_API_KEY}",
      "api_key": "${PERPLEXITY_API_KEY}"
    }
  },
  "order": {
    "ollama": ["ollama:default"],
    "groq": ["groq:default"],
    "perplexity": ["perplexity:default"]
  }
}
